st = int(input())
stop = int(input())

found = False  # to check if any prime exists

for n in range(st, stop + 1):
    if n > 1:
        is_prime = True  # reset for each number
        
        for i in range(2, n):
            if n % i == 0:
                is_prime = False
                break
        
        if is_prime:
            print(n)
            found = True

if not found:
    print("No primes")
